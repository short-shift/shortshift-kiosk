<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="48dp">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Velg WiFi-nettverk"
        android:textColor="#FFFFFF"
        android:textSize="36sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Koble skjermen til internett"
        android:textColor="#888888"
        android:textSize="20sp"
        android:layout_marginBottom="32dp" />

    <ScrollView
        android:id="@+id/networkScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#111111">

        <LinearLayout
            android:id="@+id/networkList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:divider="?android:attr/listDivider"
            android:showDividers="middle" />
    </ScrollView>

    <LinearLayout
        android:id="@+id/passwordLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:id="@+id/selectedNetworkText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="18sp"
            android:layout_marginBottom="24dp" />

        <EditText
            android:id="@+id/passwordInput"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:hint="Skriv inn passord"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:textSize="24sp"
            android:background="#222222"
            android:padding="16dp"
            android:inputType="textPassword"
            android:imeOptions="actionDone"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/backButton"
                android:layout_width="180dp"
                android:layout_height="56dp"
                android:text="Tilbake"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#333333"
                android:layout_marginEnd="16dp" />

            <Button
                android:id="@+id/connectButton"
                android:layout_width="180dp"
                android:layout_height="56dp"
                android:text="Koble til"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4CAF50" />
        </LinearLayout>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textSize="18sp"
        android:visibility="gone"
        android:layout_marginTop="8dp" />

</LinearLayout>
