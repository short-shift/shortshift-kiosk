<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/shortshift_black">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="48dp">

        <TextView
            android:id="@+id/logoText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ShortShift"
            android:textColor="@color/shortshift_white"
            android:textSize="48sp"
            android:textStyle="bold"
            android:layout_marginBottom="48dp" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@color/shortshift_white"
            android:visibility="gone"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_ready"
            android:textColor="@color/shortshift_white"
            android:textSize="24sp"
            android:textAlignment="center"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/deviceSuffixText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/shortshift_gray"
            android:textSize="16sp"
            android:textAlignment="center" />

    </LinearLayout>

</FrameLayout>
